# Copie para config.env (o setup.sh também gera isso interativamente).
# NÃO commitar config.env — contém token/senha. Já está no .gitignore.

# --- Home Assistant ---
HA_BASE_URL=http://192.168.1.90:8123
HA_TOKEN=                       # Perfil -> Segurança -> Token de longa duração

# --- Frigate ---
FRIGATE_URL=http://192.168.1.110:5000

# --- Android TV ---
ANDROIDTV_IP=192.168.1.190

# --- Dispositivo de TV ---
# DEVICE_TYPE: 1=Fire TV (PIP) | 2=Xiaomi/Android TV sem PIP (overlay) | 3=outro
DEVICE_TYPE=2
APP_MODE=overlay                # pip | overlay
APP_PKG=com.frigate.tvx         # com.frigate.tv (PIP) | com.frigate.tvx (overlay)
APP_REPO=duarte-gui/FrigateTV4Xiaomi
OVERLAY_PKG=com.frigate.tvx

# --- Como enviar o package do HA ---
HA_COPY_METHOD=manual           # smb | ssh | manual
HA_SMB_USER=homeassistant
HA_SMB_PASS=
HA_SSH=                         # ex.: root@192.168.1.90 (addon SSH)
